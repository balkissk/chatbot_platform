DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/chatbot_db?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
FRONTEND_URL=https://your-frontend.azurewebsites.net
ALLOWED_ORIGINS=https://your-frontend.azurewebsites.net
API_BASE_URL=https://your-backend.azurewebsites.net
PUBLIC_API_BASE_URL=https://your-backend.azurewebsites.net

AI_PROVIDER=azure_openai
EMBEDDING_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=replace-with-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# AZURE_OPENAI_ENDPOINT must be the resource endpoint only.
# Do not include /openai, /deployments, or a model path.
